# AI Customer Service Demo — 環境變數設定
# cp .env.example .env

# ── 必填：伺服器對外 IP ────────────────────────────────────────
# 本機保持 localhost:5001，遠端改為 http://<SERVER_IP>:5001
DIFY_API_URL=http://localhost:5001

# ── 啟動後填入（從各服務 UI 取得）────────────────────────────────
# Dify: http://<SERVER_IP>:3000 → App → API Access
DIFY_API_KEY=

# AnythingLLM: http://<SERVER_IP>:3001 → Settings → API Keys
ANYTHINGLLM_API_KEY=
ANYTHINGLLM_WORKSPACE=ai-customer-service

# ── Ollama ────────────────────────────────────────────────────
# 模型會在容器啟動時自動下載，可選其他模型: qwen2, mistral 等
OLLAMA_MODEL=llama3.1:8b

# ── LiveChat ──────────────────────────────────────────────────
# my.livechat.com → Settings → Chat widget
LIVECHAT_LICENSE_ID=
# my.livechat.com → 右上角帳號 → Personal Access Tokens → base64 encode
LIVECHAT_TOKEN=
# 回應平台: dify | anythingllm | both
LIVECHAT_ACTIVE_PLATFORM=both
