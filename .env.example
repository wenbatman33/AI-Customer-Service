# AI Customer Service Demo — 環境變數設定
# cp .env.example .env

# ── Dify ──────────────────────────────────────────────────────
# 遠端部署時改為伺服器 IP，本機保持 localhost:5001
# 遠端: http://<SERVER_IP>:5001
DIFY_API_URL=http://localhost:5001
DIFY_DB_USER=dify
DIFY_DB_PASSWORD=difypassword
DIFY_DB_NAME=dify
DIFY_SECRET_KEY=your-dify-secret-key-change-me
DIFY_SANDBOX_KEY=sandbox-secret-change-me
# 啟動後從 http://localhost:3000 → App → API Access 取得
DIFY_API_KEY=

# ── AnythingLLM ───────────────────────────────────────────────
ANYTHINGLLM_JWT_SECRET=anythingllm-jwt-secret-change-me
# 啟動後從 http://localhost:3001 → Settings → API Keys 取得
ANYTHINGLLM_API_KEY=
ANYTHINGLLM_WORKSPACE=ai-customer-service

# ── Ollama ────────────────────────────────────────────────────
# Ollama 必須安裝在主機（不在 Docker 內），並先執行: ollama pull llama3.1:8b
# 預設連本機 host，若 Ollama 在其他機器則改為對應 IP
OLLAMA_BASE_PATH=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.1:8b

# ── LiveChat ──────────────────────────────────────────────────
# my.livechat.com → Settings → Chat widget
LIVECHAT_LICENSE_ID=
# my.livechat.com → 右上角帳號 → Personal Access Tokens → base64 encode
LIVECHAT_TOKEN=
# 回應平台: dify | anythingllm | both
LIVECHAT_ACTIVE_PLATFORM=both
