# ============================================================
# AI Customer Service Demo — 環境變數設定
# 複製此檔為 .env 並填入實際值
# cp .env.example .env
# ============================================================

# ── Dify ────────────────────────────────────────────────────
# Dify 資料庫
DIFY_DB_USER=dify
DIFY_DB_PASSWORD=difypassword
DIFY_DB_NAME=dify

# Dify 安全金鑰 (請修改為隨機字串)
DIFY_SECRET_KEY=your-dify-secret-key-change-me

# Dify Sandbox API Key
DIFY_SANDBOX_KEY=sandbox-secret-change-me

# Dify App API Key (從 Dify 管理介面建立 App 後取得)
# 路徑: http://localhost:3000 → 建立 App → API Access → API Key
DIFY_API_KEY=

# ── AnythingLLM ─────────────────────────────────────────────
# AnythingLLM JWT 金鑰 (請修改為隨機字串)
ANYTHINGLLM_JWT_SECRET=anythingllm-jwt-secret-change-me

# AnythingLLM API Key (從管理介面取得)
# 路徑: http://localhost:3001 → Settings → API Keys
ANYTHINGLLM_API_KEY=

# AnythingLLM Workspace slug (小寫，與管理介面建立的 Workspace 名稱一致)
ANYTHINGLLM_WORKSPACE=ai-customer-service

# ── Ollama ──────────────────────────────────────────────────
# Ollama 模型名稱 (需先在本機執行 ollama pull <model>)
# 推薦: llama3.1:8b, qwen2, mistral
OLLAMA_MODEL=llama3.1:8b

# ── LiveChat Inc. ───────────────────────────────────────────
# 從 https://my.livechat.com → Settings → Chat widget 取得
LIVECHAT_LICENSE_ID=

# LiveChat PAT Token（用於 RTM WebSocket 自動回覆，不需要 ngrok）
# 取得方式: my.livechat.com → 右上角帳號 → Personal Access Tokens → 建立新 token → base64 encode
LIVECHAT_TOKEN=

# Webhook 方式（需要 ngrok，可選）
# 從 LiveChat Developer Console → Apps → Credentials 取得
LIVECHAT_CLIENT_ID=
LIVECHAT_CLIENT_SECRET=

# 哪個平台的回應發回 LiveChat: dify | anythingllm | both(並排顯示)
LIVECHAT_ACTIVE_PLATFORM=both
